{
  "name": "alchemistry",
  "private": true,
  "version": "0.1.0",
  "description": "Transmute documents, images, audio, and video into fresh artifacts.",
  "author": "Roman Grinevich",
  "license": "MIT",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "tsc -b && electron-vite build",
    "build:mac": "npm run build && electron-builder --mac dmg",
    "lint": "eslint .",
    "preview": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "test": "vitest run",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@fontsource-variable/eb-garamond": "^5.2.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/cinzel": "^5.2.8",
    "@fontsource/cinzel-decorative": "^5.2.8",
    "@imgly/background-removal-node": "^1.4.5",
    "ffmpeg-static": "^5.3.0",
    "lottie-web": "^5.13.0",
    "lucide-react": "^1.18.0",
    "marked": "^18.0.5",
    "motion": "^12.40.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  }
}
